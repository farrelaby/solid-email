{
  "name": "solid-email-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "build": "pnpm --filter @solid-email/render --filter @akin01/solid-email run build",
    "test": "pnpm --filter @solid-email/render --filter @akin01/solid-email run test",
    "test:e2e": "vitest run --config e2e/vitest.config.ts",
    "typecheck": "pnpm --filter @solid-email/render --filter @akin01/solid-email run typecheck && pnpm typecheck:e2e",
    "typecheck:e2e": "tsc -p e2e/tsconfig.json --noEmit && tsc -p e2e/vite/tsconfig.json --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "release:github": "node scripts/create-github-releases.mjs",
    "release:github:dry-run": "node scripts/create-github-releases.mjs --dry-run"
  },
  "devDependencies": {
    "@solid-email/render": "workspace:*",
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "solid-js": "catalog:",
    "@akin01/solid-email": "workspace:*",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
