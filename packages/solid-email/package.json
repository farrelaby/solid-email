{
  "name": "@akin01/solid-email",
  "version": "0.1.2",
  "description": "High-quality Solid components for creating emails",
  "repository": {
    "type": "git",
    "url": "https://github.com/Akin01/solid-email"
  },
  "type": "module",
  "types": "./dist/index.d.mts",
  "files": [
    "dist/**"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch src",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:e2e": "vitest run --config ../../e2e/vitest.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@solid-email/render": "workspace:*",
    "css-tree": "catalog:",
    "marked": "catalog:",
    "prismjs": "catalog:",
    "tailwindcss": "catalog:"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@types/css-tree": "catalog:",
    "@types/prismjs": "catalog:",
    "solid-js": "catalog:",
    "tsconfig": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vite-plugin-solid": "catalog:",
    "vitest": "catalog:"
  }
}
