// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`should handle outside-body content depending on base element options > empty base element selectors to include entire document even in presence of body

\`\`\`html
<html><body>
<div id="outside-hat">OUTSIDE_HAT</div>
<section id="main-a" class="pick common">
  <p>MAIN_A_P1</p>
  <p>MAIN_A_P2</p>
</section>
<div id="outside-footer">OUTSIDE_FOOTER</div>
</body>
<section id="main-b" class="common">
  <p>MAIN_B_P1</p>
</section>
</html>
\`\`\`

\`\`\`options
{
  "baseElements": {
    "returnDomByDefault": true,
    "selectors": []
  }
}
\`\`\` 1`] = `
"OUTSIDE_HAT

MAIN_A_P1

MAIN_A_P2

OUTSIDE_FOOTER

MAIN_B_P1"
`;

exports[`should handle outside-body content depending on base element options > only base element content is included by default

\`\`\`html
<html><body>
<div id="outside-hat">OUTSIDE_HAT</div>
<section id="main-a" class="pick common">
  <p>MAIN_A_P1</p>
  <p>MAIN_A_P2</p>
</section>
<div id="outside-footer">OUTSIDE_FOOTER</div>
</body>
<section id="main-b" class="common">
  <p>MAIN_B_P1</p>
</section>
</html>
\`\`\`

\`\`\`options
{
  "baseElements": {
    "returnDomByDefault": true
  }
}
\`\`\` 1`] = `
"OUTSIDE_HAT

MAIN_A_P1

MAIN_A_P2

OUTSIDE_FOOTER"
`;

exports[`should not repeat the same base element > \`\`\`html
<html><body>
<div id="outside-hat">OUTSIDE_HAT</div>
<section id="main-a" class="pick common">
  <p>MAIN_A_P1</p>
  <p>MAIN_A_P2</p>
</section>
<section id="main-b" class="common">
  <p>MAIN_B_P1</p>
</section>
<section id="main-c" class="pick">
  <p>MAIN_C_P1</p>
  <p>MAIN_C_P2</p>
  <p>MAIN_C_P3</p>
  <p>MAIN_C_P4</p>
  <p>MAIN_C_P5</p>
</section>
<div id="outside-footer">OUTSIDE_FOOTER</div>
</body></html>
\`\`\`

\`\`\`options
{
  "baseElements": {
    "selectors": [
      "#main-a",
      "#main-a"
    ]
  }
}
\`\`\` 1`] = `
"MAIN_A_P1

MAIN_A_P2"
`;

exports[`should only retrieve and convert content under the specified base element if found > \`\`\`html
