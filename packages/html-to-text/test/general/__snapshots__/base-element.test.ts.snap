exports[`should respect maxBaseElements limit > \`\`\`html
<html><body>
<div id="outside-hat">OUTSIDE_HAT</div>
<section id="main-a" class="pick common">
  <p>MAIN_A_P1</p>
  <p>MAIN_A_P2</p>
</section>
<section id="main-b" class="common">
  <p>MAIN_B_P1</p>
</section>
<section id="main-c" class="pick">
  <p>MAIN_C_P1</p>
  <p>MAIN_C_P2</p>
  <p>MAIN_C_P3</p>
  <p>MAIN_C_P4</p>
  <p>MAIN_C_P5</p>
</section>
<div id="outside-footer">OUTSIDE_FOOTER</div>
</body></html>
\`\`\`

\`\`\`options
{
  "baseElements": {
    "orderBy": "occurrence",
    "selectors": [
      "p"
    ]
  },
  "limits": {
    "maxBaseElements": 5
  }
}
\`\`\` 1`] = `
"MAIN_A_P1

MAIN_A_P2

MAIN_B_P1

MAIN_C_P1

MAIN_C_P2"
`;

