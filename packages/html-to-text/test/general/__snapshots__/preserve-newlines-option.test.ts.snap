B


C"
`;

exports[`should not preserve newlines by default > \`\`\`html
<p
>One
Two
Three</p>
\`\`\` 1`] = `"One Two Three"`;

exports[`should preserve line feeds in a long string containing line feeds across the wrap > \`\`\`html
