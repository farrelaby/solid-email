exports[`should account for trailing/leading linebreaks of adjacent blocks equally > \`\`\`html
<p>A</p>
<div>B</div>
<div>C</div>
<p>D</p>
\`\`\`

\`\`\`options
{
  "preserveNewlines": true
}
\`\`\` 1`] = `
"A


B

C


D"
`;

exports[`should have no special behavior in presence of words among linebreaks > \`\`\`html
