// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`should not add ellipsis when maxChildNodes limit is exact match > \`\`\`html
<!DOCTYPE html><html><head></head><body><p>a</p><p>b</p><p>c</p><p>d</p><p>e</p><p>f</p><p>g</p><p>h</p><p>i</p><p>j</p></body></html>
\`\`\`

\`\`\`options
{
  "limits": {
    "ellipsis": "can't see me",
    "maxChildNodes": 10
  },
  "selectors": [
    {
      "options": {
        "leadingLineBreaks": 1,
        "trailingLineBreaks": 1
      },
      "selector": "p"
    }
  ]
}
\`\`\` 1`] = `
"a
b
c
d
e
f
g
h
i
j"
`;

exports[`should respect maxChildNodes limit > \`\`\`html
<!DOCTYPE html><html><head></head><body><p>a</p><p>b</p><p>c</p><p>d</p><p>e</p><p>f</p><p>g</p><p>h</p><p>i</p><p>j</p></body></html>
\`\`\`

\`\`\`options
{
  "limits": {
    "ellipsis": "(skipped the rest)",
    "maxChildNodes": 6
  },
  "selectors": [
    {
      "options": {
        "leadingLineBreaks": 1,
        "trailingLineBreaks": 1
      },
      "selector": "p"
    }
  ]
}
\`\`\` 1`] = `
"a
b
c
d
e
f
(skipped the rest)"
`;

exports[`should respect maxDepth limit > \`\`\`html
<!DOCTYPE html><html><head></head><body><span>a<span>b<span>c<span>d</span>e</span>f</span>g<span>h<span>i<span>j</span>k</span>l</span>m</span></body></html>
\`\`\`

\`\`\`options
{
  "limits": {
    "ellipsis": "(...)",
    "maxDepth": 2
  }
}
\`\`\` 1`] = `"a(...)g(...)m"`;

exports[`should use default ellipsis value if none provided > \`\`\`html
<!DOCTYPE html><html><head></head><body><p>a</p><p>b</p><p>c</p><p>d</p><p>e</p><p>f</p><p>g</p><p>h</p><p>i</p><p>j</p></body></html>
\`\`\`

\`\`\`options
{
  "limits": {
    "maxChildNodes": 6
  },
  "selectors": [
    {
      "options": {
        "leadingLineBreaks": 1,
        "trailingLineBreaks": 1
      },
      "selector": "p"
    }
  ]
}
\`\`\` 1`] = `
"a
b
c
d
e
f
..."
`;
