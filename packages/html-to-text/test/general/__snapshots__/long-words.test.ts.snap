exports[`should split long strings in links and hide href when text matches > \`\`\`html
<a href="http://images.fb.com/2015/12/21/ivete-sangalo-launches-360-music-video-on-facebook/">http://images.fb.com/2015/12/21/ivete-sangalo-launches-360-music-video-on-facebook/</a>
\`\`\`

\`\`\`options
{
  "longWordSplit": {
    "forceWrapOnLimit": false,
    "wrapCharacters": [
      "/",
      "_"
    ]
  },
  "selectors": [
    {
      "options": {
        "hideLinkHrefIfSameAsText": true
      },
      "selector": "a"
    }
  ]
}
\`\`\` 1`] = `
"http://images.fb.com/2015/12/21/
ivete-sangalo-launches-360-music-video-on-facebook/"
`;

