// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`should ignore html comments > \`\`\`html

    <!--[^-]*-->
    <!-- <h1>Hello World</h1> -->
    text
  
\`\`\` 1`] = `"text"`;

exports[`should ignore scripts > \`\`\`html

    <script src="javascript.js"></script>
    <script>
      console.log("Hello World!");
    </script>
    <script id="data" type="application/json">{"userId":1234,"userName":"John Doe","memberSince":"2000-01-01T00:00:00.000Z"}</script>
    text
  
\`\`\` 1`] = `"text"`;

exports[`should ignore styles > \`\`\`html

    <link href="main.css" rel="stylesheet">
    <style type="text/css" media="all and (max-width: 500px)">
      p { color: #26b72b; }
    </style>
    text
  
\`\`\` 1`] = `"text"`;

exports[`should not break after special tag followed by an entity > \`\`\`html
<style>a{}</style>&apos;<br/><span>text</span>
\`\`\` 1`] = `
"'
text"
`;
