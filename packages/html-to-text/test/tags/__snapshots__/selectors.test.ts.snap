// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`should allow escape sequences in selectors > \`\`\`html
<hr id="sceneI_3.1"/><hr class="---"/>
\`\`\`

\`\`\`options
{
  "selectors": [
    {
      "format": "blockString",
      "options": {
        "string": "---[ cut ]---"
      },
      "selector": "#sceneI_3\\\\.1"
    },
    {
      "format": "blockString",
      "options": {
        "string": "---[ cut ]---"
      },
      "selector": ".\\\\2d -\\\\-"
    }
  ]
}
\`\`\` 1`] = `
"---[ cut ]---

---[ cut ]---"
`;

exports[`should merge entries with the same selector > \`\`\`html
<foo></foo><foo></foo><foo></foo>
\`\`\`

\`\`\`options
{
  "selectors": [
    {
      "format": "somethingElse",
      "selector": "foo"
    },
    {
      "options": {
        "length": 20
      },
      "selector": "foo"
    },
    {
      "options": {
        "leadingLineBreaks": 4
      },
      "selector": "foo"
    },
    {
      "options": {
        "trailingLineBreaks": 4
      },
      "selector": "foo"
    },
    {
      "options": {
        "length": 10
      },
      "selector": "foo"
    },
    {
      "format": "horizontalLine",
      "selector": "foo"
    }
  ]
}
\`\`\` 1`] = `
"----------



----------



----------"
`;

exports[`should pick the last selector of equal specificity > \`\`\`html
<hr class="bar baz"/><hr class="foo bar"/><hr class="foo baz"/>
\`\`\`

\`\`\`options
{
  "selectors": [
    {
      "format": "horizontalLine",
      "options": {
        "length": 7
      },
      "selector": "hr.foo"
    },
    {
      "format": "horizontalLine",
      "options": {
        "length": 3
      },
      "selector": "hr.baz"
    },
    {
      "format": "horizontalLine",
      "options": {
        "length": 5
      },
      "selector": "hr.bar"
    },
    {
      "selector": "hr.foo"
    }
  ]
}
\`\`\` 1`] = `
"-----

-------

-------"
`;

exports[`should pick the most specific selector > \`\`\`html
<hr/><hr class="foo" id="bar"/>
\`\`\`

\`\`\`options
{
  "selectors": [
    {
      "options": {
        "length": 3
      },
      "selector": "hr"
    },
    {
      "format": "horizontalLine",
      "options": {
        "length": 5
      },
      "selector": "hr#bar"
    },
    {
      "format": "horizontalLine",
      "options": {
        "length": 7
      },
      "selector": "hr.foo"
    }
  ]
}
\`\`\` 1`] = `
"---

-----"
`;

exports[`should support certain pseudo-classes > \`\`\`html
<foo>foo1</foo> <foo>foo2</foo> <foo><foo>foo3</foo></foo> <foo><!-- foo4 --></foo> <foo id="foo5"></foo> <foo>foo6</foo> <foo>foo7</foo>
\`\`\`

\`\`\`options
{
  "selectors": [
    {
      "format": "inline",
      "selector": "foo"
    },
    {
      "format": "inlineString",
      "options": {
        "string": "empty"
      },
      "selector": "foo:empty"
    },
    {
      "format": "inlineString",
      "options": {
        "string": "first-child"
      },
      "selector": "foo:first-child"
    },
    {
      "format": "inlineString",
      "options": {
        "string": "last-child"
      },
      "selector": "foo:last-child"
    },
    {
      "format": "inlineString",
      "options": {
        "string": "only-child"
      },
      "selector": "foo:only-child"
    }
  ]
}
\`\`\` 1`] = `"first-child foo2 only-child empty empty foo6 last-child"`;

exports[`should support the :any-link pseudo-class > \`\`\`html
<foo href="#foo">foo</foo> <a href="#a">a1</a> <a>a2</a> <area href="#area" alt="area1"/> <area alt="area2"/>
\`\`\`

\`\`\`options
{
  "selectors": [
    {
      "format": "inlineString",
      "options": {
        "string": "area"
      },
      "selector": "area"
    },
    {
      "format": "inlineString",
      "options": {
        "string": "any-link"
      },
      "selector": ":any-link"
    }
  ]
}
\`\`\` 1`] = `"foo any-link a2 any-link area"`;
