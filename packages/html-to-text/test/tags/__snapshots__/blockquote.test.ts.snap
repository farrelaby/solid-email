// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`should format multi-line blockquote > multi-line blockquote

\`\`\`html
<blockquote>a<br/>b</blockquote>
\`\`\` 1`] = `
"> a
> b"
`;

exports[`should handle format single-line blockquote > single-line blockquote

\`\`\`html
foo<blockquote>test</blockquote>bar
\`\`\` 1`] = `
"foo

> test

bar"
`;

exports[`should trim newlines unless disabled > blockquote default trim

\`\`\`html
<blockquote><br/>a<br/><br/><br/></blockquote>
\`\`\` 1`] = `"> a"`;

exports[`should trim newlines unless disabled > blockquote trim disabled

\`\`\`html
<blockquote><br/>a<br/><br/><br/></blockquote>
\`\`\`

\`\`\`options
{
  "selectors": [
    {
      "options": {
        "trimEmptyLines": false
      },
      "selector": "blockquote"
    }
  ]
}
\`\`\` 1`] = `
"> 
> a
> 
> 
> "
`;
