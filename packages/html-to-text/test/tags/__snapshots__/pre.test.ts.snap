// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`should support preformatted text with a table > \`\`\`html

<pre><table>
    <tr>
        <td>[a&#32;&#32;&#32;
     </td>
        <td>  b&#32;&#32;
     </td>
        <td>   c]
     </td>
    </tr>
    <tr>
        <td>&#32;&#32;&#32;&#32;&#32;
   d]</td>
        <td>&#32;&#32;&#32;&#32;&#32;
  e  </td>
        <td>&#32;&#32;&#32;&#32;&#32;
[f   </td>
    </tr>
</table></pre>
\`\`\`

\`\`\`options
{
  "selectors": [
    {
      "format": "dataTable",
      "selector": "table"
    }
  ]
}
\`\`\` 1`] = `
"[a        b        c]
                     
                     
   d]     e     [f   "
`;

exports[`should support preformatted text with inner tags > \`\`\`html
<p>Code fragment:</p>
<pre><code>  var total = 0;

  <em style="color: green;">// Add 1 to total and display in a paragraph</em>
  <strong style="color: blue;">document.write('&lt;p&gt;Sum: ' + (total + 1) + '&lt;/p&gt;');</strong></code></pre>
\`\`\` 1`] = `
"Code fragment:

  var total = 0;

  // Add 1 to total and display in a paragraph
  document.write('<p>Sum: ' + (total + 1) + '</p>');"
`;

exports[`should support preformatted text with line break tags > \`\`\`html
<pre> line 1 <br/> line 2 </pre>
\`\`\` 1`] = `
" line 1 
 line 2 "
`;

exports[`should support simple preformatted text > \`\`\`html
<P>Code fragment:</P><PRE>  body {
    color: red;
  }</PRE>
\`\`\` 1`] = `
"Code fragment:

  body {
    color: red;
  }"
`;
