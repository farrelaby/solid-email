exports[`should handle unordered list prefix option > \`\`\`html
<ul><li>foo</li><li>bar</li></ul>
\`\`\`

\`\`\`options
{
  "selectors": [
    {
      "options": {
        "itemPrefix": " test "
      },
      "selector": "ul"
    }
  ]
}
\`\`\` 1`] = `
" test foo
 test bar"
`;

exports[`should handle unordered list with multiple elements > \`\`\`html
<ul><li>foo</li><li>bar</li></ul>
\`\`\` 1`] = `
" * foo
 * bar"
`;

exports[`should not wrap list items when wordwrap is disabled > \`\`\`html
Good morning Jacob,
    <p>Lorem ipsum dolor sit amet</p>
    <p><strong>Lorem ipsum dolor sit amet.</strong></p>
    <ul>
      <li>run in the park <span style="color:#888888;">(in progress)</span></li>
    </ul>
  
\`\`\`

\`\`\`options
{
  "wordwrap": false
}
\`\`\` 1`] = `
"Good morning Jacob,

Lorem ipsum dolor sit amet

Lorem ipsum dolor sit amet.

 * run in the park (in progress)"
`;

