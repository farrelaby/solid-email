exports[`should handle nested ordered lists correctly > \`\`\`html
<ol><li>foo<ol><li>bar<ol><li>baz</li><li>baz</li></ol></li></ol></li></ol>
\`\`\` 1`] = `
" 1. foo
    1. bar
       1. baz
       2. baz"
`;

exports[`should handle nested unordered lists correctly > \`\`\`html
<ul><li>foo<ul><li>bar<ul><li>baz.1</li><li>baz.2</li></ul></li></ul></li></ul>
\`\`\` 1`] = `
" * foo
   * bar
     * baz.1
     * baz.2"
`;

exports[`should handle non-li elements inside a list gracefully > \`\`\`html

    <ul>
      <li>list item</li>
      plain text
      <li>list item</li>
      <div>div</div>
      <li>list item</li>
      <p>paragraph</p>
      <li>list item</li>
    </ul>
  
\`\`\` 1`] = `
" * list item
   plain text
 * list item
   div
 * list item

   paragraph

 * list item"
`;

